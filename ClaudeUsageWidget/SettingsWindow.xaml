<Window x:Class="ClaudeUsageWidgetProvider.SettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        WindowStyle="None"
        ShowInTaskbar="True"
        ResizeMode="NoResize"
        AllowsTransparency="True"
        Background="Transparent"
        SizeToContent="WidthAndHeight"
        WindowStartupLocation="CenterScreen"
        Title="Claude Usage Widget Settings">
    <Border Background="#1C1C1C" CornerRadius="8" Padding="16,12"
            MouseLeftButtonDown="Border_MouseLeftButtonDown">
        <StackPanel Width="260">
            <TextBlock Text="Settings" Foreground="White" FontSize="14" FontWeight="SemiBold" Margin="0,0,0,12"/>

            <CheckBox x:Name="NotificationsCheck" Content="Threshold notifications (75%, 90%)"
                      Foreground="White" FontSize="11" Margin="0,0,0,8"/>

            <CheckBox x:Name="NotifyResetCheck" Content="Notify on limit reset"
                      Foreground="White" FontSize="11" Margin="0,0,0,8"/>

            <Border Height="1" Background="#333333" Margin="0,4,0,8"/>

            <CheckBox x:Name="StartupCheck" Content="Run at startup"
                      Foreground="White" FontSize="11" Margin="0,0,0,12"/>

            <Grid>
                <TextBlock x:Name="VersionText" Foreground="#555555" FontSize="9"
                           VerticalAlignment="Center"/>
                <Button x:Name="CloseButton" Content="Close" HorizontalAlignment="Right"
                        Padding="16,4" FontSize="11" Cursor="Hand"
                        Background="#333333" Foreground="White" BorderBrush="#555555"/>
            </Grid>
        </StackPanel>
    </Border>
</Window>

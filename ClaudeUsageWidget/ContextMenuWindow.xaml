<Window x:Class="ClaudeUsageWidgetProvider.ContextMenuWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        WindowStyle="None"
        ShowInTaskbar="False"
        ShowActivated="True"
        ResizeMode="NoResize"
        AllowsTransparency="True"
        Background="Transparent"
        SizeToContent="WidthAndHeight"
        Title="Claude Usage Widget Menu">
    <Border Background="#1C1C1C" CornerRadius="6" Padding="4,4">
        <StackPanel x:Name="ItemsPanel"/>
    </Border>
</Window>
